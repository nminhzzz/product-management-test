extends ../../layouts/default.pug
include ../../mixins/select-tree

block main
    h1(class="mb-4") #{pageTitle}

    form(
        action=`${prefixAdmin}/articles/edit/${article.id}?_method=PATCH`
        method="POST"
        enctype="multipart/form-data"
    )
        div(class="form-group")
            label(for="title") Tiêu đề
            input(
                type="text"
                class="form-control"
                id="title"
                name="title"
                required
                value=article.title
            )
        div(class="form-group")
            label(for="parent_id") Danh mục bài viết
            select(
                name="article_category_id"
                id="article_category_id"
                class="form-control"
            )
                option(value="") ---chọn danh mục bài viết---
                if(articleCategory)
                    +select-tree(articleCategory,1,article.article_category_id)
        div(class="form-group")
            label(for="desc") Nội dung bài viết
            textarea(
                class="form-control textarea-mce"
                id="desc"
                name="description"
                rows="5"
            ) #{article.description}
        div(
        class="form-group"
        upload-image
        )
            label(for="thumbnail") Ảnh
            input(
                type="file"
                class="form-control-file"
                id="thumbnail"
                name="thumbnail"
                accept="image/*"
                upload-image-input
            )
            img(
                src=article.thumbnail
                class="image-preview"
                upload-image-preview
            )
        div(class="form-group")
            label(for="position") Vị trí
            input(
                type="number"
                class="form-control"
                id="position"
                name="position"
                placeholder="Tự động tăng"
                min="1"
                value=article.position
            )
        div(class="form-group form-check form-check-inline")
            input(
                type="radio"
                class="form-check-input"
                id="statusActive"
                name="status"
                value="active"
                checked=(article.status == "active" ? true : false)
            )
            label(for="statusActive" class="form-check-label") Hoạt động
        div(class="form-group form-check form-check-inline")
            input(
                type="radio"
                class="form-check-input"
                id="statusInActive"
                name="status"
                value="inactive"
                checked=(article.status == "inactive" ? true : false)
            )
            label(for="statusInActive" class="form-check-label") Dừng hoạt động
        div(class="form-group")
            button(
                type="submit"
                class="btn btn-primary"
            ) Cập nhật
    script(src="/admin/js/product.js")
