mixin sub-menu(items)
  ul
    each item in items
      li
        a(href=`/products/${item.slug}`) #{item.title}
        if(item.children)
          +sub-menu(item.children)

mixin sub-menu-article(items)
  ul
    each item in items
      li
        a(href=`/articles/${item.slug}`) #{item.title}
        if(item.children)
          +sub-menu-article(item.children)