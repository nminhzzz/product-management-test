extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
  .container.my-5
    .row
      .col-md-6.mx-auto
        +box-head(pageTitle)

        form(action="/user/password/reset" method="POST")
          .form-group
            label(for="password") Mật khẩu mới
            input.form-control(
              type="password"
              id="password"
              name="password"
              placeholder="Nhập mật khẩu mới"
              required
            )

          .form-group.mt-3
            label(for="confirmPassword") Nhập lại mật khẩu
            input.form-control(
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              placeholder="Nhập lại mật khẩu"
              required
            )

          .form-group.mt-4
            button.btn.btn-primary.btn-block(type="submit") Đổi mật khẩu